{
  "manifest_version": 3,
  "name": "Steven's Job Autocompleter",
  "version": "1.1",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://*.linkedin.com/*", "https://*.greenhouse.io/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*", "https://*.greenhouse.io/*"],
      "js": ["content.js"]
    }
  ]
}
